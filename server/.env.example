# HTTP
PORT=3000
# CORS: comma-separated origins the desktop client connects from (or * for dev)
CORS_ORIGIN=*

# PostgreSQL
DATABASE_URL=postgresql://aireader:aireader@localhost:5432/aireader?schema=public

# JWT (CHANGE THESE in production)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=2592000     # seconds (30 days)

# CAS single sign-on (the only login method)
CAS_BASE_URL=https://account.d2ssoft.com
# Public origin of THIS server (used to build the CAS service/callback URL)
PLATFORM_HOST=https://aireader.d2ssoft.com

# S3 / MinIO (attachment storage)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ai-reader
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
