// Windows VERSIONINFO resource, generated by CMake (configure_file @ONLY) from
// project(ai-reader VERSION ...). This is the single source of truth for the
// app version: it stamps ai-reader.exe's Properties -> Details, and AiReader.iss
// reads ProductVersion straight back out of the built exe. Bump the version in
// CMakeLists.txt only.
//
// Numeric literals (no <winver.h> include) keep this self-contained:
//   FILEOS      0x40004L = VOS_NT_WINDOWS32
//   FILETYPE    0x1L     = VFT_APP

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         0x40004L
 FILETYPE       0x1L
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "AI Reader\0"
            VALUE "FileDescription",  "AI Reader\0"
            VALUE "FileVersion",      "@PROJECT_VERSION@\0"
            VALUE "InternalName",     "ai-reader\0"
            VALUE "OriginalFilename", "ai-reader.exe\0"
            VALUE "ProductName",      "AI Reader\0"
            VALUE "ProductVersion",   "@PROJECT_VERSION@\0"
            VALUE "LegalCopyright",   "Copyright (C) AI Reader contributors\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
